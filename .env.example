# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/pnmzimtzzvmifqfcvefo/settings/api

# Your Supabase project URL (e.g., https://pnmzimtzzvmifqfcvefo.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (for edge functions - NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Configuration
# Get from: https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Stripe publishable key for client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Vercel OIDC Token (auto-injected by Vercel)
VERCEL_OIDC_TOKEN=
