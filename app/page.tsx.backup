      <section id="open-source" className="terminal-section py-24">
        <div className="max-w-full mx-0 px-0">
          <div className="px-6 mb-6">
            <div className="flex items-center gap-3 mb-4">
              <Terminal className="w-5 h-5 text-green-600" />
