# CrewCircle Mobile App Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================
# SUPABASE (Required for Mobile Auth & Database)
# ============================================================
# Get these from: https://app.supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# EXPO PUSH NOTIFICATIONS (Required for Push)
# ============================================================
# Get your project ID from: https://expo.dev → Your Project → Settings
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id

# ============================================================
# SETUP STEPS
# ============================================================
# 1. Create Supabase project → get URL and anon key
# 2. Create Expo project → get project ID
# 3. Copy this file to .env.local
# 4. Fill in the values above
# 5. Run: eas credentials (iOS) or configure Android
